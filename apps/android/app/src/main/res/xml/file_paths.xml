<!-- FileProvider paths. Both are under the app cache — never long-lived
     message content. Nothing else in the app's storage is reachable through
     a content URI. -->
<paths>
    <!-- QR-drop sticker PNG written for a one-shot share/print. -->
    <cache-path name="dropshare" path="dropshare/" />
    <!-- Camera-capture staging for TakePicture. Deleted immediately after
         AttachmentLoader reads the bytes into memory (zero-persistence). -->
    <cache-path name="cameracapture" path="cameracapture/" />
</paths>
