<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The ONLY permissions this app requests. No contacts, no storage,
         no location. CAMERA is used solely to scan a contact's QR code (their
         public routing ID + key); the app never records or stores images. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- A camera is optional — devices without one still install and work
         (QR scanning is simply unavailable); paste/link add still functions. -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Required on Android 11+ (package-visibility filtering) to detect the
         external router apps. Without these, getPackageInfo/getLaunchIntentForPackage
         silently report "not installed" for every package not listed here. -->
    <queries>
        <!-- Orbot (Tor). -->
        <package android:name="org.torproject.android" />
        <!-- Official I2P app — the router Zitrone wires (HTTP proxy 4444 via
             CONNECT). Ships under BOTH ids: net.i2p.android (Play/canonical) and
             net.i2p.android.router (F-Droid). -->
        <package android:name="net.i2p.android" />
        <package android:name="net.i2p.android.router" />
        <!-- i2pd — no longer wired; detected only so the UI can tell an i2pd-only
             user that Zitrone now uses the official I2P app for relay routing. -->
        <package android:name="org.purplei2p.i2pd" />
    </queries>

    <application
        android:name=".ZitroneApp"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Zitrone"
        tools:targetApi="34">

        <!-- Single-activity app. FLAG_SECURE is applied in onCreate BEFORE
             setContent — every Activity that can render message content must
             do the same (critical rule). -->
        <!-- The launcher activity must be exported (mandatory since API 31 for
             any activity with an intent-filter); it exposes no privileged
             control surface — content sits behind the biometric gate. -->
        <!-- nosemgrep: java.android.security.exported_activity.exported_activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Zitrone">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- QR dead-drop ("lemon drop") deep links: https://zitrone.app/d/…
                 A SEPARATE intent-filter from MAIN/LAUNCHER on purpose — multiple
                 <data> elements in one filter cross-product into unintended matches.
                 https ONLY (no http): a security-focused messenger, and extra schemes
                 block App Links verification. autoVerify checks
                 https://zitrone.app/.well-known/assetlinks.json, which ships with the
                 marketing site (website/public/.well-known/ — see
                 docs/RELEASING_ANDROID.md for the runbook and re-verification lag).
                 Wherever verification hasn't (yet) succeeded, Android 12+ silently
                 opens these links in the browser and the site serves the ordinary
                 marketing page at /d/{id} — the DESIGNED no-app fallback, not a bug.
                 In-app handling: MainActivity.handleDeepLink raises the advocacy
                 veil and classifies the drop's state with one blind fetch. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="zitrone.app" />
                <data android:pathPrefix="/d/" />
            </intent-filter>
        </activity>

        <!-- QR scanner for contact exchange. Subclasses ZXing's CaptureActivity
             only to apply FLAG_SECURE (see SecureCaptureActivity). Not exported —
             launched in-process, never by another app. -->
        <activity
            android:name=".ui.components.SecureCaptureActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.Zitrone" />

        <!-- Share a saved QR-drop sticker (a public drop link, never message
             content) to a printer/gallery app via a read-only, per-share content
             URI. grantUriPermissions + no exported access: only the explicit
             ACTION_SEND grant reaches the cached PNG. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
