# Copy to apps/android/keystore.properties (gitignored) and fill in to build a
# SIGNED release APK locally:
#
#   cd apps/android && ./gradlew :app:assembleRelease
#
# app/build.gradle.kts reads these four values. As an alternative to this file,
# the release CI workflow (.github/workflows/release-apk.yml) supplies the same
# values via environment variables sourced from GitHub Secrets:
#
#   ANDROID_KEYSTORE_FILE      storeFile
#   ANDROID_KEYSTORE_PASSWORD  storePassword
#   ANDROID_KEY_ALIAS          keyAlias
#   ANDROID_KEY_PASSWORD       keyPassword
#
# When none are provided the release build is simply UNSIGNED (installable only
# after signing it with apksigner). See docs/RELEASING_ANDROID.md.
#
# NEVER commit the real keystore.properties or the .jks — both are gitignored.
# Use the SAME keystore that signed the previous release, or existing installs
# cannot update over the top (Android rejects a signature change).

# Path to your release keystore, relative to apps/android/ (or absolute).
storeFile=release.jks
storePassword=CHANGE_ME
keyAlias=sublemonable
keyPassword=CHANGE_ME
