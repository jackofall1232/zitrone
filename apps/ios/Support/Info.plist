<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Sublemonable</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.5.1</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<!-- Baked in at build time from the RELAY_ONION_ADDRESS build setting (see
	     Configuration/Release.xcconfig). NEVER published or committed — empty
	     string when the build did not set it. Read via RelayConfig.onionAddress
	     (Sources/Networking/RelayConfig.swift). -->
	<key>RELAY_ONION_ADDRESS</key>
	<string>$(RELAY_ONION_ADDRESS)</string>
	<!-- Empty launch screen: the system shows a plain dark screen, then the
	     SplashView lemon-slice sequence takes over. -->
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>NSFaceIDUsageDescription</key>
	<string>Face ID keeps your encrypted messages locked to you. Your biometric data never leaves this device.</string>
	<key>NSCameraUsageDescription</key>
	<string>The camera is used only to scan a contact's QR code. No images are stored or transmitted.</string>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<!-- Orbot deep link for the opt-in Tor toggle. -->
		<string>orbot</string>
		<!-- Jailbreak heuristic (warn-only): detects Cydia presence. -->
		<string>cydia</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- The app uses standard (Signal Protocol / TLS) encryption. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<true/>
	<!-- No ATS exceptions: HTTPS only; TLS 1.3 minimum is enforced in code
	     (URLSessionConfiguration.tlsMinimumSupportedProtocolVersion) together
	     with certificate pinning (PinnedSessionDelegate). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>
</dict>
</plist>
