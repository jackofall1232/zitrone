# Sublemonable server configuration — copy to .env and edit.
# See docs/SELF_HOSTING.md for the full reference.

DATABASE_URL=postgres://sub:sub@localhost:5432/sublemonable?sslmode=disable
JWT_PRIVATE_KEY_PATH=./keys/jwt.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt.pub.pem
SERVER_PORT=8443
# Leave TLS paths empty when terminating TLS at a reverse proxy
TLS_CERT_PATH=
TLS_KEY_PATH=
MAX_PREKEYS_PER_USER=100
MESSAGE_TTL_UNDELIVERED_HOURS=72
RATE_LIMIT_ENABLED=true

# ── Tor hidden services ───────────────────────────────────────────────────────
# Three separate hidden services run on the same box (see docs/TOR_ARCHITECTURE.md).
# Set all three after running:
#   docker compose exec tor cat /var/lib/tor/<dir>/hostname

# Published in docs and sublemonable.com — serves the static APK mirror.
PUBLIC_ONION_ADDRESS=
# Unpublished — word-of-mouth only. Separate .onion, same mirror content.
SECRET_ONION_ADDRESS=
# Unpublished — baked into app binary. Serves the API relay only (no mirror).
RELAY_ONION_ADDRESS=
# Master switch — set true after reading all three .onion addresses above.
TOR_ENABLED=false

# ── I2P relay transport (optional) ───────────────────────────────────────────
# Start the overlay: docker compose -f docker-compose.yml -f docker-compose.i2p.yml up -d
# After first startup (allow 1-2 min for tunnel build), read the B32 destination:
#   curl -s 'http://127.0.0.1:7070/?page=i2p_tunnels' | grep -oP '[a-z2-7]+\.b32\.i2p' | head -1
# Set I2P_EEPSITE_DEST to that address; export RELAY_I2P_DEST for desktop builds:
#   export RELAY_I2P_DEST=<b32address>.b32.i2p && pnpm tauri build
# Back up i2p-data volume (sublemonable-relay.dat) — losing it loses the B32 address.
I2P_ENABLED=false
I2P_EEPSITE_DEST=   # paste *.b32.i2p address from i2pd web console (127.0.0.1:7070)

# ── v1.5 ──────────────────────────────────────────────────────────────────────
# Legacy single onion address (pre-v1.5). Still honoured: when set and
# PUBLIC_ONION_ADDRESS is empty, it is treated as the public mirror address.
ONION_ADDRESS=
# Dead drops: lifetime and proof-of-work difficulty (leading zero bits on deposit).
DROP_TTL_HOURS=72
DROP_POW_DIFFICULTY=20
# Relay node: set BOTH to a base64 Curve25519 keypair to act as a multi-hop relay
# and serve POST /relay/forward. Leave empty for a plain message server.
RELAY_PRIVATE_KEY=
RELAY_PUBLIC_KEY=
# Allowlist of next-hop forward URLs this relay may forward to (comma-separated).
# Forwarding fails closed when empty — an SSRF guard, since the next hop comes
# from a packet anyone can seal to this relay's public key.
RELAY_PEERS=
